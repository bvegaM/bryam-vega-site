---
import Base from './Base.astro';
import { formatDate, seriesFragmentId } from '../lib/series';
import { withBase } from '../lib/paths';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  tags?: string[];
  series?: string;
  heroImage?: string;
  heroImageCaption?: string;
  canonical?: string;
  noIndex?: boolean;
}
const {
  title, description, pubDate, updatedDate,
  tags = [], series, heroImage, heroImageCaption, canonical, noIndex,
} = Astro.props;

/** Raster heroes fill a fixed aspect box; SVG keeps intrinsic sizing + letterboxing. */
const heroIsRaster =
  typeof heroImage === 'string' &&
  /\.(png|jpe?g|webp|gif|avif)(\?|#|$)/i.test(heroImage);
---

<Base title={`${title} — Bryam Vega`} description={description} ogType="article" heroImage={heroImage} noIndex={noIndex}>
  <div class="container">
    <article>
      <header class="article-head">
        <span class="label">
          Essay · {formatDate(pubDate)}
          {updatedDate && <> · updated {formatDate(updatedDate)}</>}
        </span>
        <h1>{title}</h1>
        <p class="desc">{description}</p>
        {series && (
          <p class="label article-series-ref" style="margin-top: 1rem;">
            Part of <a href={`${withBase('/series/')}#${seriesFragmentId(series)}`} class="label-accent">{series}</a>
          </p>
        )}
      </header>

      {heroImage && (
        <figure class:list={['article-hero', heroIsRaster && 'article-hero--raster']}>
          {heroIsRaster ? (
            <div class="article-hero-media">
              <img src={heroImage.startsWith('/') ? withBase(heroImage) : heroImage} alt={heroImageCaption ?? title} />
            </div>
          ) : (
            <img src={heroImage.startsWith('/') ? withBase(heroImage) : heroImage} alt={heroImageCaption ?? title} />
          )}
          {heroImageCaption && <figcaption class="article-hero-caption">{heroImageCaption}</figcaption>}
        </figure>
      )}

      <slot />

      {tags.length > 0 && (
        <div class="tags">
          {tags.map((tg) => <span class="tag">{tg}</span>)}
        </div>
      )}

      {canonical && (
        <p class="label" style="margin-top: 2.5rem;">
          Originally published at <a href={canonical} target="_blank" rel="noopener">{canonical}</a>
        </p>
      )}

      <hr />
      <p class="label">← <a href={withBase('/blog/')}>All essays</a></p>
    </article>
  </div>
</Base>
